[user]
  name = blurrcat
  email = blurrcat@pm.me
[core]
  editor = nvim
  excludesfile = ~/.gitignore
  pager = delta
[interactive]
  diffFilter = delta --color-only

[push]
	default = current
[merge]
  ff = no
[alias]
  co = checkout
  br = branch
  ci = commit
  st = status
  last = "log -1 HEAD"
  unstage = "reset HEAD --"
  hist = "log --decorate --graph --oneline --all"
  df = "diff -w --patience"
[pull]
  rebase = true
[delta]
  navigate = true
[merge]
  conflictStyle = zdiff3
