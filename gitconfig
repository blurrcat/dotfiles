[user]
  name = blurrcat
  email = blurrcat@pm.me
[core]
  editor = nvim
  excludesfile = ~/.gitignore
[push]
  default = matching
[merge]
  ff = no
[alias]
  co = checkout
  br = branch
  ci = commit
  st = status
  last = "log -1 HEAD"
  unstage = "reset HEAD --"
  hist = "log --decorate --graph --oneline --all"
[pull]
  rebase = true
